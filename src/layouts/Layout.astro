---
import '../styles/global.css'
import ApiStatus from '../components/ApiStatus.astro';

let supabaseOrigin = '';

try {
	const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
	if (supabaseUrl) {
		supabaseOrigin = new URL(supabaseUrl).origin;
	}
} catch {
	supabaseOrigin = '';
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#0c2443" />
		{supabaseOrigin && <link rel="dns-prefetch" href={supabaseOrigin} />}
		{supabaseOrigin && <link rel="preconnect" href={supabaseOrigin} crossorigin />}
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Portafolio profesional de MT - Desarrollador web especializado en tecnologías modernas" />
		<meta name="author" content="MT" />
		<title>MT - Portafolio</title>
	</head>
	<body>
		<a class="skip-link" href="#home">Saltar al contenido principal</a>
		<slot />
		<!-- Indicador de estado de API solo en desarrollo -->
		<ApiStatus />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
