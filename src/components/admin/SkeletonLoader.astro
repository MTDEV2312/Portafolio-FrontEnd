---
// src/components/admin/SkeletonLoader.astro
// Skeleton screens contextuales para diferentes tipos de carga

interface Props {
  type: 'dashboard' | 'profile' | 'projects-list' | 'project-card' | 'form';
  count?: number; // Para listas
}

const { type, count = 1 } = Astro.props;
---

{type === 'dashboard' && (
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 animate-pulse">
    {[...Array(2)].map(() => (
      <div class="bg-muted rounded-xl p-6 h-32"></div>
    ))}
  </div>
)}

{type === 'profile' && (
  <div class="space-y-6 animate-pulse">
    <div class="bg-muted rounded-lg h-8 w-3/4"></div>
    <div class="space-y-4">
      {[...Array(4)].map(() => (
        <div class="space-y-2">
          <div class="bg-muted h-4 w-1/4 rounded"></div>
          <div class="bg-muted h-10 w-full rounded"></div>
        </div>
      ))}
    </div>
    <div class="bg-muted h-12 w-1/4 rounded"></div>
  </div>
)}

{type === 'projects-list' && (
  <div class="space-y-4 animate-pulse">
    {[...Array(count)].map(() => (
      <div class="border border-border rounded-lg p-4 space-y-3">
        <div class="flex justify-between items-start">
          <div class="bg-muted h-6 w-1/3 rounded"></div>
          <div class="bg-muted h-6 w-1/6 rounded"></div>
        </div>
        <div class="bg-muted h-4 w-full rounded"></div>
        <div class="bg-muted h-4 w-5/6 rounded"></div>
        <div class="flex gap-2">
          {[...Array(3)].map(() => (
            <div class="bg-muted h-8 w-1/4 rounded"></div>
          ))}
        </div>
      </div>
    ))}
  </div>
)}

{type === 'project-card' && (
  <div class="bg-card rounded-xl overflow-hidden shadow animate-pulse border border-border">
    <div class="w-full h-48 bg-muted"></div>
    <div class="p-6 space-y-3">
      <div class="h-6 bg-muted rounded w-3/4"></div>
      <div class="h-4 bg-muted rounded"></div>
      <div class="h-4 bg-muted rounded w-5/6"></div>
      <div class="flex gap-2 pt-2">
        {[...Array(2)].map(() => (
          <div class="h-8 bg-muted rounded flex-1"></div>
        ))}
      </div>
    </div>
  </div>
)}

{type === 'form' && (
  <div class="space-y-6 animate-pulse">
    {[...Array(3)].map(() => (
      <div class="space-y-2">
        <div class="bg-muted h-4 w-1/4 rounded"></div>
        <div class="bg-muted h-10 w-full rounded"></div>
      </div>
    ))}
    <div class="bg-muted h-12 w-1/3 rounded"></div>
  </div>
)}

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
