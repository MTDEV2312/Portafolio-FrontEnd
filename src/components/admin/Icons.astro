---
// src/components/admin/Icons.astro
// Iconos SVG simples para reemplazar Font Awesome

interface Props {
  icon: keyof typeof ICONS;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const SIZE_MAP = {
  sm: '16',
  md: '24',
  lg: '32',
  xl: '40',
};

const ICONS = {
  'gear': '<circle cx="12" cy="12" r="1"/><path d="M12 1v6m0 6v6M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24M1 12h6m6 0h6M4.22 19.78l4.24-4.24m5.08-5.08l4.24-4.24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'lock': '<rect x="3" y="10" width="18" height="12" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="16" r="1" fill="currentColor"/>',
  'user': '<circle cx="12" cy="8" r="4"/><path d="M3 20c1.1-3 4-5 9-5s7.9 2 9 5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'folder': '<path d="M22 19a2 2 0 0 1-2.414-.646l-6.359-7.639A2 2 0 0 0 9.172 10H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'tachometer': '<circle cx="12" cy="12" r="9"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 1-3 3-3 3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="17" r="1" fill="currentColor"/>',
  'logout': '<path d="M10 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h4m7-7l5-5m0 0l-5-5m5 5H9" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'plus': '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  'edit': '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'trash': '<polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  'check': '<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'x': '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  'alert': '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'github': '<path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 0c4.3 1.4 4.3-2.5 6-3M9 3h6v7H9z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'external-link': '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6m0-3h6v6m-6-6l9-9" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  'spinner': '<g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"><circle cx="12" cy="12" r="10" opacity="0.2"/><circle cx="12" cy="12" r="10" stroke-dasharray="15.7 47.1" style="animation: spin 1s linear infinite"/></g>',
} as const;

const { icon, size = 'md', class: classes = '' } = Astro.props;
const sizeValue = SIZE_MAP[size];

const iconContent = ICONS[icon];
if (!iconContent) {
  throw new Error(`Icon "${icon}" not found`);
}
---

<svg 
  xmlns="http://www.w3.org/2000/svg" 
  width={sizeValue} 
  height={sizeValue} 
  viewBox="0 0 24 24"
  class={`inline-block ${classes}`}
  set:html={iconContent}
/>

<style>
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  svg[data-icon="spinner"] {
    animation: spin 1s linear infinite;
  }
</style>
