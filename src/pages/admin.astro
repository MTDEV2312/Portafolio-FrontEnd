---
import Layout from '../layouts/Layout.astro';
import SkeletonLoader from '../components/admin/SkeletonLoader.astro';
import Icons from '../components/admin/Icons.astro';

// Panel de Administración - Optimizado
// ✅ Cache global (AdminStateManager)
// ✅ Deduplicación de fetches (DataManager)
// ✅ Validación en tiempo real
// ✅ Skeletons en lugar de spinners
// ✅ Tabla con paginación
// ✅ UI simplificada
---

<Layout>
    <style>
        .section {
            display: block;
        }
        .section.hidden {
            display: none !important;
        }
        .nav-btn.active {
            background-color: rgb(var(--primary)) !important;
            color: rgb(var(--primary-foreground)) !important;
        }
        .form-error {
            border-color: rgb(var(--error)) !important;
        }
        .form-error::after {
            content: attr(data-error);
            display: block;
            color: rgb(var(--error));
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .message {
            animation: slideIn 0.3s ease;
        }
        table tbody tr {
            border-bottom: 1px solid rgb(var(--border));
            transition: background-color 0.2s;
        }
        table tbody tr:hover {
            background-color: rgba(var(--primary), 0.02);
        }
        .pagination-btn:not(:disabled) {
            cursor: pointer;
        }
        .pagination-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
    </style>

    <div class="min-h-screen bg-card">
        <!-- Header -->
        <div class="bg-card border-b border-border shadow-sm">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="p-2 bg-primary rounded-lg">
                            <Icons icon="gear" size="lg" class="text-primary-foreground" />
                        </div>
                        <div>
                            <h1 class="text-2xl font-bold text-primary">Panel de Administración</h1>
                            <p class="text-muted-foreground text-sm">Gestiona tu portfolio de manera eficiente</p>
                        </div>
                    </div>
                    <button id="logout-btn" class="hidden bg-error text-error-foreground px-4 py-2 rounded-lg hover:bg-error/90 transition-colors text-sm font-medium flex items-center space-x-2">
                        <Icons icon="logout" size="sm" />
                        <span>Cerrar Sesión</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Auth Section -->
        <div id="auth-section" class="max-w-md mx-auto mt-12 px-4">
            <div class="bg-card rounded-xl shadow border border-border p-8">
                <div class="text-center mb-8">
                    <div class="p-3 bg-primary/10 rounded-full w-16 h-16 mx-auto mb-4 flex items-center justify-center">
                        <Icons icon="lock" size="lg" class="text-primary" />
                    </div>
                    <h2 class="text-2xl font-bold text-card-foreground">Iniciar Sesión</h2>
                    <p class="text-muted-foreground text-sm mt-2">Accede al panel de administración</p>
                </div>
                
                <div id="login-error" class="hidden bg-error/10 border border-error/20 text-error rounded-lg p-4 mb-6 message">
                    <div class="flex items-center space-x-2">
                        <Icons icon="alert" size="md" />
                        <span id="login-error-text"></span>
                    </div>
                </div>
                
                <div id="login-success" class="hidden bg-success/10 border border-success/20 text-success rounded-lg p-4 mb-6 message">
                    <div class="flex items-center space-x-2">
                        <Icons icon="check" size="md" />
                        <span id="login-success-text"></span>
                    </div>
                </div>
                
                <form id="login-form" class="space-y-6">
                    <div>
                        <label for="email" class="block text-sm font-medium text-card-foreground mb-2">Email</label>
                        <input type="email" id="email" required 
                               class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm">
                    </div>
                    <div>
                        <label for="password" class="block text-sm font-medium text-card-foreground mb-2">Contraseña</label>
                        <input type="password" id="password" required 
                               class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm">
                    </div>
                    <button type="submit" class="w-full bg-primary text-primary-foreground py-2 px-4 rounded-lg hover:bg-primary/90 transition-colors font-medium text-sm">
                        Iniciar Sesión
                    </button>
                </form>
            </div>
        </div>

        <!-- Admin Panel -->
        <div id="admin-panel" class="hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                <!-- Sidebar -->
                <div class="lg:col-span-1">
                    <div class="bg-card rounded-lg shadow border border-border p-4 sticky top-8">
                        <h3 class="text-lg font-semibold text-card-foreground mb-4">Navegación</h3>
                        <nav class="space-y-2">
                            <button class="nav-btn active w-full text-left px-4 py-2 rounded-lg transition-colors flex items-center space-x-2 bg-primary text-primary-foreground text-sm font-medium" data-section="dashboard">
                                <Icons icon="tachometer" size="md" />
                                <span>Dashboard</span>
                            </button>
                            <button class="nav-btn w-full text-left px-4 py-2 rounded-lg transition-colors flex items-center space-x-2 text-muted-foreground hover:bg-muted hover:text-card-foreground text-sm font-medium" data-section="profile">
                                <Icons icon="user" size="md" />
                                <span>Perfil</span>
                            </button>
                            <button class="nav-btn w-full text-left px-4 py-2 rounded-lg transition-colors flex items-center space-x-2 text-muted-foreground hover:bg-muted hover:text-card-foreground text-sm font-medium" data-section="projects">
                                <Icons icon="folder" size="md" />
                                <span>Proyectos</span>
                            </button>
                        </nav>
                    </div>
                </div>

                <!-- Main Content -->
                <div class="lg:col-span-3">
                    <!-- Dashboard Section -->
                    <div id="dashboard" class="section">
                        <div class="bg-card rounded-lg shadow border border-border p-8">
                            <h2 class="text-2xl font-bold text-card-foreground mb-6 flex items-center space-x-3">
                                <Icons icon="tachometer" size="lg" class="text-primary" />
                                <span>Dashboard</span>
                            </h2>
                            <div id="dashboard-loading">
                                <SkeletonLoader type="dashboard" />
                            </div>
                            <div id="stats" class="hidden">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="bg-primary text-primary-foreground p-6 rounded-lg">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <h3 id="total-projects" class="text-3xl font-bold">0</h3>
                                                <p class="text-primary-foreground/80 text-sm">Proyectos Totales</p>
                                            </div>
                                            <Icons icon="folder" size="xl" class="text-primary-foreground/60" />
                                        </div>
                                    </div>
                                    <div class="bg-success text-success-foreground p-6 rounded-lg">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <h3 id="profile-status" class="text-xl font-semibold">No configurado</h3>
                                                <p class="text-success-foreground/80 text-sm">Estado del Perfil</p>
                                            </div>
                                            <Icons icon="user" size="xl" class="text-success-foreground/60" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Profile Section -->
                    <div id="profile" class="section hidden">
                        <div class="bg-card rounded-lg shadow border border-border p-8">
                            <h2 class="text-2xl font-bold text-card-foreground mb-6 flex items-center space-x-3">
                                <Icons icon="user" size="lg" class="text-primary" />
                                <span>Gestión de Perfil</span>
                            </h2>
                            
                            <div id="profile-messages"></div>
                            
                            <div id="profile-loading">
                                <SkeletonLoader type="profile" />
                            </div>
                            
                            <div id="profile-content" class="hidden space-y-6">
                                <form id="profile-form" class="space-y-6">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            <label for="nombre" class="block text-sm font-medium text-card-foreground mb-2">Nombre</label>
                                            <input type="text" id="nombre" required 
                                                   class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm"
                                                   placeholder="Tu nombre completo">
                                            <span id="nombre-error" class="hidden text-error text-xs mt-1 block"></span>
                                        </div>
                                        <div>
                                            <label for="contactEmail" class="block text-sm font-medium text-card-foreground mb-2">Email de Contacto</label>
                                            <input type="email" id="contactEmail" required 
                                                   class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm"
                                                   placeholder="tu@email.com">
                                            <span id="contactEmail-error" class="hidden text-error text-xs mt-1 block"></span>
                                        </div>
                                    </div>
                                    <div>
                                        <label for="perfilUrl" class="block text-sm font-medium text-card-foreground mb-2">URL de Imagen de Perfil</label>
                                        <input type="url" id="perfilUrl" required 
                                               class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm"
                                               placeholder="https://...">
                                        <p class="text-xs text-muted-foreground mt-1">URL pública de tu foto de perfil</p>
                                        <span id="perfilUrl-error" class="hidden text-error text-xs mt-1 block"></span>
                                    </div>
                                    <div>
                                        <label for="aboutMeDescription" class="block text-sm font-medium text-card-foreground mb-2">Descripción About Me</label>
                                        <textarea id="aboutMeDescription" rows="4" required 
                                                  class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm resize-none"
                                                  placeholder="Cuéntame sobre ti..."></textarea>
                                        <span id="aboutMeDescription-error" class="hidden text-error text-xs mt-1 block"></span>
                                    </div>
                                    <button type="submit" class="bg-success text-success-foreground py-2 px-6 rounded-lg hover:bg-success/90 transition-colors font-medium text-sm flex items-center space-x-2">
                                        <Icons icon="check" size="md" />
                                        <span>Guardar Perfil</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Projects Section -->
                    <div id="projects" class="section hidden">
                        <div class="bg-card rounded-lg shadow border border-border p-8">
                            <div class="flex items-center justify-between mb-6">
                                <h2 class="text-2xl font-bold text-card-foreground flex items-center space-x-3">
                                    <Icons icon="folder" size="lg" class="text-primary" />
                                    <span>Gestión de Proyectos</span>
                                </h2>
                                <button id="new-project-btn" class="bg-primary text-primary-foreground py-2 px-4 rounded-lg hover:bg-primary/90 transition-colors font-medium text-sm flex items-center space-x-2">
                                    <Icons icon="plus" size="md" />
                                    <span>Nuevo</span>
                                </button>
                            </div>
                            
                            <div id="projects-messages"></div>

                            <!-- Project Form (Hidden by default) -->
                            <div id="project-form-container" class="hidden bg-muted rounded-lg p-6 mb-8 border border-border">
                                <h3 id="project-form-title" class="text-lg font-semibold text-card-foreground mb-6">Nuevo Proyecto</h3>
                                <form id="project-form" class="space-y-6">
                                    <input type="hidden" id="project-id">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            <label for="project-title" class="block text-sm font-medium text-card-foreground mb-2">Título</label>
                                            <input type="text" id="project-title" required 
                                                   class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm"
                                                   placeholder="Nombre del proyecto">
                                            <span id="project-title-error" class="hidden text-error text-xs mt-1 block"></span>
                                        </div>
                                        <div>
                                            <label for="project-image" class="block text-sm font-medium text-card-foreground mb-2">Imagen</label>
                                            <input type="file" id="project-image" accept="image/*" 
                                                   class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-xs file:font-medium file:bg-primary file:text-primary-foreground hover:file:bg-primary/90">
                                            <span id="project-image-error" class="hidden text-error text-xs mt-1 block"></span>
                                        </div>
                                    </div>
                                    <div>
                                        <label for="project-description" class="block text-sm font-medium text-card-foreground mb-2">Descripción</label>
                                        <textarea id="project-description" rows="3" required 
                                                  class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm resize-none"
                                                  placeholder="Descripción del proyecto..."></textarea>
                                        <span id="project-description-error" class="hidden text-error text-xs mt-1 block"></span>
                                    </div>
                                    <div>
                                        <label for="project-tech" class="block text-sm font-medium text-card-foreground mb-2">Tecnologías</label>
                                        <input type="text" id="project-tech" placeholder="React, Node.js, MongoDB" required 
                                               class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm">
                                        <p class="text-xs text-muted-foreground mt-1">Separa con comas</p>
                                        <span id="project-tech-error" class="hidden text-error text-xs mt-1 block"></span>
                                    </div>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            <label for="project-github" class="block text-sm font-medium text-card-foreground mb-2">GitHub (opcional)</label>
                                            <input type="url" id="project-github" 
                                                   class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm"
                                                   placeholder="https://github.com/...">
                                            <span id="project-github-error" class="hidden text-error text-xs mt-1 block"></span>
                                        </div>
                                        <div>
                                            <label for="project-demo" class="block text-sm font-medium text-card-foreground mb-2">Demo (opcional)</label>
                                            <input type="url" id="project-demo" 
                                                   class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-input text-sm"
                                                   placeholder="https://...">
                                            <span id="project-demo-error" class="hidden text-error text-xs mt-1 block"></span>
                                        </div>
                                    </div>
                                    <div class="flex items-center space-x-4">
                                        <button type="submit" class="bg-success text-success-foreground py-2 px-6 rounded-lg hover:bg-success/90 transition-colors font-medium text-sm flex items-center space-x-2">
                                            <Icons icon="check" size="md" />
                                            <span>Guardar</span>
                                        </button>
                                        <button type="button" id="cancel-project" class="bg-error text-error-foreground py-2 px-6 rounded-lg hover:bg-error/90 transition-colors font-medium text-sm flex items-center space-x-2">
                                            <Icons icon="x" size="md" />
                                            <span>Cancelar</span>
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <!-- Projects Table -->
                            <div id="projects-loading">
                                <SkeletonLoader type="projects-list" count={3} />
                            </div>
                            
                            <div id="projects-content" class="hidden">
                                <div id="projects-table-container"></div>
                                <div id="pagination" class="hidden mt-6 flex items-center justify-between text-sm">
                                    <span id="pagination-info" class="text-muted-foreground"></span>
                                    <div class="flex gap-2">
                                        <button id="prev-page" class="pagination-btn px-3 py-2 border border-border rounded hover:bg-muted transition-colors text-sm">← Anterior</button>
                                        <button id="next-page" class="pagination-btn px-3 py-2 border border-border rounded hover:bg-muted transition-colors text-sm">Siguiente →</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { adminState } from '../services/adminState';
        import { AuthMiddleware } from '../services/authMiddleware';
        import { ApiClient } from '../services/apiClient';

        // ApiClient maneja el API_BASE_URL automáticamente
        
        let projectsCurrentPage = 1;
        const PROJECTS_PER_PAGE = 10;
        let allProjects: any[] = [];

        declare global {
            interface Window {
                editProject: (id: number) => Promise<void>;
                deleteProject: (id: number) => Promise<void>;
            }
        }

        function showMessage(containerId: string, message: string, isError: boolean = false, duration: number = 5000) {
            const container = document.getElementById(containerId);
            if (!container) return;

            const messageEl = document.createElement('div');
            messageEl.className = `bg-${isError ? 'error' : 'success'}/10 border border-${isError ? 'error' : 'success'}/20 text-${isError ? 'error' : 'success'} rounded-lg p-4 mb-6 message flex items-center space-x-2`;
            messageEl.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    ${isError ? '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>' : '<polyline points="20 6 9 17 4 12"/>'}
                </svg>
                <span>${message}</span>
            `;
            
            container.innerHTML = '';
            container.appendChild(messageEl);
            
            setTimeout(() => {
                messageEl.remove();
            }, duration);
        }

        function validateEmail(email: string) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        }

        function validateUrl(url: string) {
            try {
                new URL(url);
                return true;
            } catch {
                return false;
            }
        }

        function validateField(field: string, value: string) {
            const errorEl = document.getElementById(`${field}-error`);
            if (!errorEl) return true;

            let isValid = true;
            let error = '';

            // Los campos github y demo son opcionales
            const isOptional = field === 'project-github' || field === 'project-demo';

            if (!value.trim()) {
                if (!isOptional) {
                    isValid = false;
                    error = 'Este campo es requerido';
                }
            } else if (field.includes('email')) {
                if (!validateEmail(value)) {
                    isValid = false;
                    error = 'Email inválido';
                }
            } else if (field.includes('url') || field.includes('Url') || field.includes('github') || field.includes('demo')) {
                if (value && !validateUrl(value)) {
                    isValid = false;
                    error = 'URL inválida';
                }
            }

            const input = document.getElementById(field);
            if (input) {
                if (isValid) {
                    input.classList.remove('form-error');
                    errorEl.classList.add('hidden');
                } else {
                    input.classList.add('form-error');
                    errorEl.textContent = error;
                    errorEl.classList.remove('hidden');
                }
            }

            return isValid;
        }

        const authSection = document.getElementById('auth-section');
        const adminPanel = document.getElementById('admin-panel');
        const loginForm = document.getElementById('login-form');
        const logoutBtn = document.getElementById('logout-btn');

        if (adminState.isAuthenticated()) {
            showAdminPanel();
        }

        if (loginForm) {
            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const email = (document.getElementById('email') as HTMLInputElement)?.value || '';
                const password = (document.getElementById('password') as HTMLInputElement)?.value || '';

                try {
                    await AuthMiddleware.login(email, password);
                    showMessage('login-success', 'Inicio de sesión exitoso');
                    setTimeout(() => showAdminPanel(), 1000);
                } catch (error) {
                    showMessage('login-error', (error as Error).message, true);
                }
            });
        }

        if (logoutBtn) {
            logoutBtn.addEventListener('click', async () => {
                await AuthMiddleware.logout();
                showAuthSection();
            });
        }

        function showAdminPanel() {
            authSection?.classList.add('hidden');
            adminPanel?.classList.remove('hidden');
            logoutBtn?.classList.remove('hidden');
            loadAllData();
        }

        function showAuthSection() {
            authSection?.classList.remove('hidden');
            adminPanel?.classList.add('hidden');
            logoutBtn?.classList.add('hidden');
        }

        function showSection(name: string) {
            document.querySelectorAll('.section').forEach(s => s.classList.add('hidden'));
            document.getElementById(name)?.classList.remove('hidden');
        }

        document.querySelectorAll('.nav-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const section = (btn as HTMLElement).dataset.section;
                if (section) {
                    showSection(section);
                    document.querySelectorAll('.nav-btn').forEach(b => {
                        b.classList.remove('active', 'bg-primary', 'text-primary-foreground');
                        b.classList.add('text-muted-foreground');
                    });
                    btn.classList.add('active', 'bg-primary', 'text-primary-foreground');
                    btn.classList.remove('text-muted-foreground');
                }
            });
        });

        const profileFields = ['nombre', 'contactEmail', 'perfilUrl', 'aboutMeDescription'];
        profileFields.forEach(field => {
            const input = document.getElementById(field) as HTMLInputElement;
            if (input) {
                input.addEventListener('blur', () => {
                    validateField(field, input.value);
                });
                input.addEventListener('input', () => {
                    if (input.classList.contains('form-error')) {
                        validateField(field, input.value);
                    }
                });
            }
        });

        const projectFields = ['project-title', 'project-description', 'project-tech', 'project-github', 'project-demo'];
        projectFields.forEach(field => {
            const input = document.getElementById(field) as HTMLInputElement;
            if (input) {
                input.addEventListener('blur', () => {
                    validateField(field, input.value);
                });
                input.addEventListener('input', () => {
                    if (input.classList.contains('form-error')) {
                        validateField(field, input.value);
                    }
                });
            }
        });

        async function loadAllData() {
            try {
                await Promise.all([
                    loadDashboard(),
                    loadProfile(),
                    loadProjects()
                ]);
            } catch (error) {
                console.error('Error cargando datos:', error);
            }
        }

        async function loadDashboard() {
            try {
                const [projects, profile] = await Promise.all([
                    ApiClient.get('/projects/read'),
                    ApiClient.get('/profiles/read')
                ]);

                (document.getElementById('total-projects') as HTMLElement).textContent = String((projects as any[]).length || 0);
                (document.getElementById('profile-status') as HTMLElement).textContent = profile ? 'Configurado' : 'No configurado';
                
                document.getElementById('dashboard-loading')?.classList.add('hidden');
                document.getElementById('stats')?.classList.remove('hidden');
            } catch (error) {
                console.error('Error en dashboard:', error);
            }
        }

        async function loadProfile() {
            try {
                const profile = await ApiClient.get('/profiles/read');
                
                const profileContent = document.getElementById('profile-content');
                const profileLoading = document.getElementById('profile-loading');

                if (profile) {
                    (document.getElementById('nombre') as HTMLInputElement).value = (profile as any).nombre;
                    (document.getElementById('contactEmail') as HTMLInputElement).value = (profile as any).contactEmail;
                    (document.getElementById('perfilUrl') as HTMLInputElement).value = (profile as any).perfilUrl;
                    (document.getElementById('aboutMeDescription') as HTMLTextAreaElement).value = (profile as any).aboutMeDescription;
                }

                profileLoading?.classList.add('hidden');
                profileContent?.classList.remove('hidden');
            } catch (error) {
                console.error('Error cargando perfil:', error);
            }
        }

        async function loadProjects() {
            try {
                const projects = await ApiClient.get('/projects/read');
                allProjects = projects as any[];
                projectsCurrentPage = 1;
                renderProjectsTable();
                
                document.getElementById('projects-loading')?.classList.add('hidden');
                document.getElementById('projects-content')?.classList.remove('hidden');
            } catch (error) {
                console.error('Error cargando proyectos:', error);
                showMessage('projects-messages', 'Error al cargar proyectos', true);
            }
        }

        function renderProjectsTable() {
            const start = (projectsCurrentPage - 1) * PROJECTS_PER_PAGE;
            const end = start + PROJECTS_PER_PAGE;
            const paginatedProjects = (allProjects as any[]).slice(start, end);
            const totalPages = Math.ceil(allProjects.length / PROJECTS_PER_PAGE);

            let html = '<div class="overflow-x-auto"><table class="w-full"><thead><tr class="border-b border-border"><th class="text-left py-3 px-4 font-semibold text-card-foreground text-sm">Proyecto</th><th class="text-left py-3 px-4 font-semibold text-card-foreground text-sm">Tecnologías</th><th class="text-left py-3 px-4 font-semibold text-card-foreground text-sm">Fecha</th><th class="text-left py-3 px-4 font-semibold text-card-foreground text-sm">Acciones</th></tr></thead><tbody>';

            if (paginatedProjects.length === 0) {
                html += '<tr><td colspan="4" class="text-center py-8 text-muted-foreground text-sm">No hay proyectos. ¡Crea tu primer proyecto!</td></tr>';
            } else {
                paginatedProjects.forEach((project: any, index: number) => {
                    const absoluteIndex = start + index;
                    const date = new Date(project.created_at).toLocaleDateString('es-ES', { month: 'short', day: 'numeric' });
                    html += `
                        <tr>
                            <td class="py-3 px-4"><span class="font-medium text-card-foreground text-sm">${project.title}</span></td>
                            <td class="py-3 px-4"><span class="text-xs text-muted-foreground">${(project.tech_section || '').split(',').slice(0, 2).join(', ')}</span></td>
                            <td class="py-3 px-4 text-sm text-muted-foreground">${date}</td>
                            <td class="py-3 px-4 space-x-2">
                                <button class="text-xs px-2 py-1 bg-warning text-warning-foreground rounded hover:bg-warning/90 transition-colors edit-project-btn" data-project-index="${absoluteIndex}">Editar</button>
                                <button class="text-xs px-2 py-1 bg-error text-error-foreground rounded hover:bg-error/90 transition-colors delete-project-btn" data-project-index="${absoluteIndex}">Eliminar</button>
                            </td>
                        </tr>
                    `;
                });
            }

            html += '</tbody></table></div>';
            document.getElementById('projects-table-container')!.innerHTML = html;

            // Agregar event listeners a los botones de editar y eliminar
            document.querySelectorAll('.edit-project-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const index = parseInt(btn.getAttribute('data-project-index') || '0', 10);
                    const project = allProjects[index];
                    if (project) {
                        (window as any).editProjectDirect(project);
                    }
                });
            });

            document.querySelectorAll('.delete-project-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const index = parseInt(btn.getAttribute('data-project-index') || '0', 10);
                    const project = allProjects[index];
                    if (project) {
                        (window as any).deleteProjectDirect(project);
                    }
                });
            });

            if (allProjects.length > PROJECTS_PER_PAGE) {
                document.getElementById('pagination-info')!.textContent = `Página ${projectsCurrentPage} de ${totalPages}`;
                (document.getElementById('prev-page') as HTMLButtonElement).disabled = projectsCurrentPage === 1;
                (document.getElementById('next-page') as HTMLButtonElement).disabled = projectsCurrentPage === totalPages;
                document.getElementById('pagination')!.classList.remove('hidden');

                document.getElementById('prev-page')!.onclick = () => {
                    projectsCurrentPage--;
                    renderProjectsTable();
                };
                document.getElementById('next-page')!.onclick = () => {
                    projectsCurrentPage++;
                    renderProjectsTable();
                };
            } else {
                document.getElementById('pagination')!.classList.add('hidden');
            }
        }

        const profileForm = document.getElementById('profile-form');
        if (profileForm) {
            profileForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                let isValid = true;
                profileFields.forEach(field => {
                    const input = document.getElementById(field) as HTMLInputElement | HTMLTextAreaElement;
                    if (!validateField(field, input.value)) {
                        isValid = false;
                    }
                });

                if (!isValid) return;

                try {
                    const data = {
                        nombre: (document.getElementById('nombre') as HTMLInputElement).value,
                        contactEmail: (document.getElementById('contactEmail') as HTMLInputElement).value,
                        perfilUrl: (document.getElementById('perfilUrl') as HTMLInputElement).value,
                        aboutMeDescription: (document.getElementById('aboutMeDescription') as HTMLTextAreaElement).value,
                    };

                    await ApiClient.post('/profiles/create', data);

                    showMessage('profile-messages', 'Perfil guardado exitosamente');
                    ApiClient.invalidateCache('/profiles/read');
                    await loadDashboard();
                } catch (error) {
                    showMessage('profile-messages', (error as Error).message, true);
                }
            });
        }

        const newProjectBtn = document.getElementById('new-project-btn');
        newProjectBtn?.addEventListener('click', () => {
            document.getElementById('project-form-title')!.textContent = 'Nuevo Proyecto';
            (document.getElementById('project-form') as HTMLFormElement).reset();
            (document.getElementById('project-id') as HTMLInputElement).value = '';
            (document.getElementById('project-image') as HTMLInputElement).required = true;
            document.getElementById('project-form-container')?.classList.remove('hidden');
        });

        document.getElementById('cancel-project')?.addEventListener('click', () => {
            document.getElementById('project-form-container')?.classList.add('hidden');
        });

        const projectForm = document.getElementById('project-form');
        if (projectForm) {
            projectForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                let isValid = true;
                projectFields.forEach(field => {
                    const input = document.getElementById(field) as HTMLInputElement;
                    if (field === 'project-github' || field === 'project-demo') {
                        if (input.value && !validateField(field, input.value)) {
                            isValid = false;
                        }
                    } else if (!validateField(field, input.value)) {
                        isValid = false;
                    }
                });

                if (!isValid) return;

                const projectId = (document.getElementById('project-id') as HTMLInputElement).value;
                const isEdit = projectId !== '';
                const imageFile = (document.getElementById('project-image') as HTMLInputElement).files?.[0];

                const formData = new FormData();
                formData.append('title', (document.getElementById('project-title') as HTMLInputElement).value);
                formData.append('description', (document.getElementById('project-description') as HTMLTextAreaElement).value);
                formData.append('techSection', (document.getElementById('project-tech') as HTMLInputElement).value);
                formData.append('github_link', (document.getElementById('project-github') as HTMLInputElement).value || '');
                formData.append('live_demo_link', (document.getElementById('project-demo') as HTMLInputElement).value || '');
                if (imageFile) formData.append('image', imageFile);

                try {
                    const url = isEdit ? `/projects/update/${projectId}` : `/projects/create`;
                    const method = isEdit ? 'PATCH' : 'POST';

                    const response = await fetch(`${ApiClient.getBaseUrl()}${url}`, {
                        method,
                        headers: { 'Authorization': `Bearer ${adminState.getToken()}` },
                        body: formData,
                    });

                    if (!response.ok) throw new Error('Error al guardar proyecto');

                    showMessage('projects-messages', `Proyecto ${isEdit ? 'actualizado' : 'creado'} exitosamente`);
                    document.getElementById('project-form-container')?.classList.add('hidden');
                    ApiClient.invalidateCache('/projects/read');
                    await loadProjects();
                    await loadDashboard();
                } catch (error) {
                    showMessage('projects-messages', (error as Error).message, true);
                }
            });
        }

        (window as any).editProjectDirect = async (project: any) => {
            if (!project) return;

            document.getElementById('project-form-title')!.textContent = 'Editar Proyecto';
            (document.getElementById('project-id') as HTMLInputElement).value = String(project.id);
            (document.getElementById('project-title') as HTMLInputElement).value = project.title;
            (document.getElementById('project-description') as HTMLTextAreaElement).value = project.description;
            (document.getElementById('project-tech') as HTMLInputElement).value = project.tech_section || '';
            (document.getElementById('project-github') as HTMLInputElement).value = project.github_link || '';
            (document.getElementById('project-demo') as HTMLInputElement).value = project.live_demo_link || '';
            (document.getElementById('project-image') as HTMLInputElement).required = false;
            document.getElementById('project-form-container')?.classList.remove('hidden');
        };

        window.editProject = async (id: number) => {
            const project = allProjects.find(p => p.id === id);
            if (project) {
                (window as any).editProjectDirect(project);
            }
        };

        (window as any).deleteProjectDirect = async (project: any) => {
            if (!project || !project.id) return;
            
            if (!confirm('¿Estás seguro de que quieres eliminar este proyecto?')) return;

            try {
                await ApiClient.delete(`/projects/delete/${project.id}`);
                showMessage('projects-messages', 'Proyecto eliminado exitosamente');
                ApiClient.invalidateCache('/projects/read');
                await loadProjects();
                await loadDashboard();
            } catch (error) {
                showMessage('projects-messages', (error as Error).message, true);
            }
        };

        window.deleteProject = async (id: number) => {
            const project = allProjects.find(p => p.id === id);
            if (project) {
                (window as any).deleteProjectDirect(project);
            }
        };
    </script>
</Layout>
