# Configuración de la API para SSG
# URL base de la API backend (con /api al final)
PUBLIC_API_URL=http://localhost:3000/api

# En producción, cambia esta URL por la de tu backend desplegado
# PUBLIC_API_URL=https://tu-backend-produccion.com/api

# Opcional: URL pública de Supabase si el backend entrega rutas de Storage relativas
# PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# URL del backend (para referencia)
BackEnd=http://localhost:3000
